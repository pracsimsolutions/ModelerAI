Reference Nodes/

# Secrets — defense in depth. Real keys live in the user's environment
# (Anthropic, OpenAI, etc.) or the DPAPI keystore, never in the repo.
.env
.env.*
*.env
# But DO commit the *.env.example template files — they're shipped
# for documentation. Any real `.env` stays caught by the rules above.
!*.env.example
!share/.env.example

# Mode B (named Cloudflare Tunnel) user config — never committed.
# share/.env is already caught by the *.env wildcard above; these
# two lines add hostname + log paths under share/cloudflared/.
share/cloudflared/config.yml
share/cloudflared/*.log
secrets.json
secrets.yaml
secrets.yml
credentials.json
keys.dat
keys.json
ModelerAI/keys.dat
set-key.*
set-env.*
load-env.*

# Build artifacts — produced by Visual Studio.
# (ModelerAI.dll is intentionally committed so users can run without building.)
ModelerAI.t
ModelerAI.exp
ModelerAI.lib
ModelerAI.pdb
ModelerAI.ipdb
ModelerAI.iobj
ModelerAiDLL/x64/
ModelerAiDLL/Win32/
ModelerAiDLL/Debug/
ModelerAiDLL/Release/
ModelerAiDLL/ModelerAI/
ModelerAiDLL/flexsimcontent/
ModelerAiDLL/*.vcxproj.user
dist/

# WiX local extension cache (created if `wix extension add` runs without --global)
.wix/

# Knowledge base — FULLY committed (2026-06-24). The entire KB ships so the module
# is self-contained: the FlexSim-derived reference layer (class/command topics,
# catalog, BM25 index) AND the converted FlexSim written manual (topics/manual/).
# Regenerate with `setup.bat` / `node tools/build-kb.js` (+ `node tools/ingest-manual.js`
# for the manual) against the local FlexSim install; re-run after a FlexSim version
# change (byte-stable, so same-version rebuilds are git no-ops). Rationale: works
# only alongside FlexSim, not redistributed standalone or sold, not claimed as
# original work. Nothing under KNOWLEDGE/ is gitignored.

# Local-only sample models / example pickups
Examples/

# Internal-only dev docs, plans, audits — not shipped publicly
docs/
CLAUDE.md
AUDIT-PRE-MIT-RELEASE.md

# Scratch / personal workflow — anything in here is local only
_local/
